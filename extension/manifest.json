{
  "manifest_version": 3,
  "name": "CareerOS Job Clipper",
  "version": "1.0.0",
  "description": "Clip jobs and auto-fill applications directly from CareerOS",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*", "https://*.greenhouse.io/*", "https://*.lever.co/*"],
      "js": ["contentScript.js"]
    }
  ]
}
