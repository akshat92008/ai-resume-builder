# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Required for production persistence)
# Without these, CareerPath AI runs in dev mode with in-memory storage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI (Required for LLM-powered resume generation)
# Without this, the builder flow will not work.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional
NODE_ENV=development
